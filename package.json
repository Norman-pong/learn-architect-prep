{
  "name": "archprep",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "server",
    "packages/*"
  ],
  "scripts": {
    "dev": "vp dev",
    "build": "vp run -r build",
    "check": "vp check",
    "lint": "vp lint",
    "fmt": "vp fmt"
  },
  "devDependencies": {
    "vite-plus": "latest"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.10.0",
      "onFail": "download"
    }
  }
}
