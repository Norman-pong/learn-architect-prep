# ArchPrep 环境变量示例
# 复制为 .env 后填写真实值，.env 文件不要提交到 Git。

# 服务端口
PORT=8787

# cloudflared 隧道域名（用于扩展 CORS 允许来源）
# 例如：archprep.example.com
CLOUDFLARED_DOMAIN=

# SMTP 邮件服务配置
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# AI API Key 加密密钥（AES-256，32 字节长度，务必保密）
AI_ENCRYPT_KEY=

# JWT 密钥（用于签发 access token 和 refresh token，请使用随机强密钥）
JWT_SECRET=
