  "strategy": {
    "quick_judgment": [
      "题1：通常是企业级/传统系统架构类",
      "题2：通常是面向对象/设计模式类",
      "题3：通常是新技术类（上云/大数据/AI）",
      "题4：通常是软件工程/项目管理/安全类"
    ],
    "selection_principles": [
      "选你最熟悉且有真实项目数据支撑的题",
      "宁可选“平淡但有数据”的题，不选“炫技但没干过”的题",
      "优先选择能套用母版项目的题目",
      "避免选择技术栈完全不熟悉或无法量化的方向"
    ],
    "preparation_plan": "准备2-3个母版项目，每个项目覆盖5-8个技术决策点。考前将历年题目按主题分类，建立题目→母版项目→技术决策点的快速映射。"
